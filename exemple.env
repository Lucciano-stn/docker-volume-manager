# ==============================
# Répertoires
# ==============================
BACKUP_DIR=""
EXCLUDE_FILE=""

# ==============================
# Logs
# ==============================
BACKUP_LOG_FILE=""
LOG_MAX_SIZE_MB=10
LOG_MAX_ROTATE=5

# ==============================
# Rétention
# ==============================
LOCAL_RETENTION_DAYS=3

# ==============================
# Backup
# ==============================
KEEP_LOCAL_BACKUP=true         # true | false
DATE_FORMAT="%Y%m%d_%H%M"
DEFAULT_BACKUP_MODE="stop"     # stop | hot
DRY_RUN=false                  # true | false

# ==============================
# Remote générique
# ==============================
REMOTE_ENABLED=true            # true | false
REMOTE_METHOD="sftp"           # sftp | none

# ==============================
# SFTP
# ==============================
SFTP_HOST=""
SFTP_PORT=22
SFTP_USER=""
SFTP_REMOTE_DIR=""
SFTP_SSH_KEY=""
SFTP_TIMEOUT=30
SFTP_RETENTION_DAYS=3
